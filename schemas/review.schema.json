{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkepticReview",
  "type": "object",
  "properties": {
    "rejection_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_experiments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "threats_to_validity": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["rejection_risks", "required_experiments", "threats_to_validity"]
}
